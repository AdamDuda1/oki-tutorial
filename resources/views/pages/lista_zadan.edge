@layout({ title: 'Lista zadań' })
  <div class="lista-zadan-page">
    <div class="lista-header">
      <h1>Lista zadań</h1>
      <span class="task-count">{{ totalCount }} zadań</span>
    </div>

    <!--div class="search-bar"
      x-data="{
        q: new URLSearchParams(location.search).get('q') || '',
        timer: null,
        search() {
          clearTimeout(this.timer);
          this.timer = setTimeout(() => {
