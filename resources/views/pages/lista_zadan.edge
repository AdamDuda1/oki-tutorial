    </div-->

    <div class="search-bar"
      x-data="{
        q: new URLSearchParams(location.search).get('q') || '',
        timer: null,
        search() {
          clearTimeout(this.timer);
          this.timer = setTimeout(async () => {
            const url = new URL(location.href);
            this.q ? url.searchParams.set('q', this.q) : url.searchParams.delete('q');
            url.searchParams.delete('page');
            history.replaceState(null, '', url);
            const res = await fetch(url, { headers: { 'X-Requested-With': 'fetch' } });
            document.querySelector('#zadania-table').innerHTML = await res.text();
          }, 300);
        }
      }">
      <input class="search-input" type="text" placeholder="Szukaj zadań..." x-model="q" @input="search()">
    </div>

  <script type="javascript">

  </script>

   <div id="zadania-table">
     @include('pages/partials/zadania_table')
  </div>
  </div>
  @!pagination({ currentPage: currentPage, totalPages: totalPages, prevUrl: prevUrl, nextUrl: nextUrl })
@end
