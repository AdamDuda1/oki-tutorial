@let(variant = $props.get('variant') || 'default')
@inject({ variant, autoDismiss: $props.get('autoDismiss') })
@let(classes = ['alert', `alert-${variant}`])

<div {{
  $props
    .except(['variant', 'autoDismiss', 'duration', 'delay'])
    .merge({
      role: 'alert',
      class: classes,
      'x-data': `alert(${$props.get('duration') ?? 5000}, ${$props.get('delay') ?? 80})`,
      'x-show': 'isVisible',
      'x-cloak': true,
    })
    .toAttrs()
}}>
  {{{ await $slots.main() }}}
</div>
