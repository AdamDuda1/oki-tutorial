@let(slot = await $slots.main())
@let(code = $props.has('code') ? $props.get('code') : slot)
@let(lang = $props.get('lang', ''))

<div class="code-block" x-data="copyable">
  <pre><code x-ref="code" class="language-{{ lang }}">{{ code }}</code></pre>
  <button type="button" class="copy-btn" :class="{ copied }"
    @click="copy($refs.code.textContent)"
    x-text="copied ? 'Skopiowano ✓' : 'Kopiuj'">Kopiuj</button>
</div>
