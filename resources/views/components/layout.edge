<!DOCTYPE html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ $props.get('title', 'Home') }} | OKI Tutorial</title>
    <link rel="preload" as="image" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Quicksand:wght@300..700&display=swap" />
    @vite(['resources/css/app.css?v=' + appVersion, 'resources/js/app.js'])
    @stack('dumper')
    <!-- Matomo -->
    <script>
      var _paq = window._paq = window._paq || [];
      /* methods like "setCustomDimension" should be called before "trackPageView" */
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="//vps-54d3f905.vps.ovh.net:8080/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '1']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>
  </head>
  <body>
    @include('partials/header')
    <main>
      @if(!$props.get('noAlerts'))
        @include('partials/flash_alerts')
      @end

      {{{ await $slots.main() }}}
    </main>

    <!--@if(process.env.VITE_FEATURE_DARK_MODE === 'true')
      <H1>DADSDSAKHJADSKHJDASHJ KDAS KJDSAJHK KJH DAS</H1>
    @endif-->
    <div class="modal-overlay" x-data x-show="$store.modal.open" style="display:none;"
      @click.self="$store.modal.hide()" @keydown.escape.window="$store.modal.hide()">
      <div class="modal-box">
        <div class="modal-header">
          <span x-text="$store.modal.title"></span>
          <button class="diff-btn-delete" @click="$store.modal.hide()">✕</button>
        </div>
        <p x-show="!$store.modal.code" x-text="$store.modal.body"></p>
        <pre x-show="$store.modal.code" x-text="$store.modal.body" class="modal-code"></pre>
      </div>
    </div>
  </body>
</html>
