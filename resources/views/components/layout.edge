<!DOCTYPE html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ $props.get('title', 'Home') }} | OKI Tutorial</title>
    <link rel="preload" as="image" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Quicksand:wght@300..700&display=swap" />
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    @stack('dumper')
    <script>
      /* Awaryjne otwieranie boxów/menu zanim załaduje się bundle z Alpine */
      (() => {
        let alpineUp = false
        document.addEventListener('alpine:init', () => { alpineUp = true })
        document.addEventListener('click', (e) => {
          if (alpineUp) return
          const trigger = e.target.closest('[data-toggle]')
          if (!trigger) return
          const interactive = e.target.closest('a, button')
          if (interactive && interactive !== trigger) return
          const root = trigger.closest('[x-data]')
          if (!root) return
          const selector = trigger.getAttribute('data-toggle') || '.box, .box-arrow, .task-box-arrow'
          for (const el of root.querySelectorAll(selector)) {
            if (el.closest('[x-data]') === root) el.classList.toggle('open')
          }
        })
      })()
    </script>
  </head>
  <body>
    @include('partials/header')
    <main>
      @if(!$props.get('noAlerts'))
        @include('partials/flash_alerts')
      @end

      {{{ await $slots.main() }}}
    </main>

    <!--@if(process.env.VITE_FEATURE_DARK_MODE === 'true')
      <H1>DADSDSAKHJADSKHJDASHJ KDAS KJDSAJHK KJH DAS</H1>
    @endif-->
    <div class="modal-overlay" x-data x-show="$store.modal.open" style="display:none;"
      @click.self="$store.modal.hide()" @keydown.escape.window="$store.modal.hide()">
      <div class="modal-box">
        <div class="modal-header">
          <span x-text="$store.modal.title"></span>
          <button class="diff-btn-delete" @click="$store.modal.hide()">✕</button>
        </div>
        <p x-show="!$store.modal.code" x-text="$store.modal.body"></p>
        <div x-show="$store.modal.code" x-data="{ copied: false }" style="position: relative;">
          <pre x-text="$store.modal.body" class="modal-code"></pre>
          <div style="display: flex; margin-bottom: -25px">
            <button type="button" class="modal-copy-btn underlinable"
              @click="navigator.clipboard.writeText($store.modal.body).then(() => { copied = true; setTimeout(() => copied = false, 1500) })"
              x-text="copied ? 'Skopiowano ✓' : 'Kopiuj'"></button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
