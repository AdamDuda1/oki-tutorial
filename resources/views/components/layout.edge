<!DOCTYPE html>
<html lang="en-us">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ $props.get('title', 'Home') }} | OKI Tutorial</title>
    <link rel="preload" as="image" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Purple+Purse&family=Quicksand:wght@300..700&display=swap" />
    @vite(['resources/css/app.css?v=2', 'resources/js/app.js'])
    @stack('dumper')
  </head>
  <body>
    @include('partials/header')
    <main>
      @if(!$props.get('noAlerts'))
        @include('partials/flash_alerts')
      @end

      {{{ await $slots.main() }}}
    </main>

    <!--@if(process.env.VITE_FEATURE_DARK_MODE === 'true')
      <H1>DADSDSAKHJADSKHJDASHJ KDAS KJDSAJHK KJH DAS</H1>
    @endif-->
    <div class="modal-overlay" x-data x-show="$store.modal.open" style="display:none;"
      @click.self="$store.modal.hide()" @keydown.escape.window="$store.modal.hide()">
      <div class="modal-box">
        <div class="modal-header">
          <span x-text="$store.modal.title"></span>
          <button class="diff-btn-delete" @click="$store.modal.hide()">✕</button>
        </div>
        <p x-show="!$store.modal.code" x-text="$store.modal.body"></p>
        <pre x-show="$store.modal.code" x-text="$store.modal.body" class="modal-code"></pre>
      </div>
    </div>
  </body>
</html>
